{
  "functions": {
    "api/**/*.php": {
      "runtime": " vercel-php@0.9"
    }
  },
  "routes": [
    {
      "src": "/chat",
      "dest": "/api/chat.php"
    },
    {
      "src": "/api/chat",
      "dest": "/api/chat.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
